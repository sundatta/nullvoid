{
  "name": "@nullvoid/bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@nullvoid/config": "workspace:*",
    "@nullvoid/database": "workspace:*",
    "@nullvoid/logger": "workspace:*",
    "@nullvoid/shared": "workspace:*",
    "@nullvoid/types": "workspace:*",
    "@nullvoid/utils": "workspace:*",
    "discord.js": "^14.16.3",
    "lavalink-client": "^2.10.3",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "eslint": "^8.57.1",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
